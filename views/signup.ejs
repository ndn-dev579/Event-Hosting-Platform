<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Evently</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f8fafc;
            background-image: 
                radial-gradient(#94a3b8 1px, transparent 1px),
                radial-gradient(#94a3b8 1px, transparent 1px);
            background-size: 20px 20px;
            background-position: 0 0, 10px 10px;
        }

        .thick-card {
            background: #ffffff;
            border: 2px solid #0f172a;
            /* Uniform 8px shadow on right and bottom for 3D block effect */
            box-shadow: 8px 8px 0px #0f172a; 
            border-radius: 20px;
            background-image: linear-gradient(#f1f5f9 1px, transparent 1px), linear-gradient(to right, #f1f5f9 1px, transparent 1px);
            background-size: 24px 24px;
        }

        .thick-input {
            width: 100%;
            background: #ffffff;
            border: 2px solid #cbd5e1;
            border-bottom-width: 4px;
            border-radius: 12px;
            padding: 12px 16px;
            font-weight: 600;
            color: #0f172a;
            transition: all 0.2s ease;
            outline: none;
            font-size: 1rem;
        }
        .thick-input:focus {
            background: #fff;
            border-color: #0f172a;
            transform: translateY(-2px);
        }

        .thick-btn {
            background-color: #0f172a;
            color: white;
            border: 2px solid #0f172a;
            border-radius: 12px;
            box-shadow: 4px 4px 0px #334155;
            transition: all 0.1s;
            font-size: 1.1rem;
        }
        .thick-btn:hover {
            transform: translate(-2px, -2px);
            box-shadow: 6px 6px 0px #334155;
        }
        .thick-btn:active {
            transform: translate(1px, 1px);
            box-shadow: 0px 0px 0px #334155;
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">

    <!-- Card: Increased width to max-w-md and padding to p-10 -->
    <div class="thick-card w-full max-w-md p-10 relative overflow-hidden">
        
        <!-- Decorative Right Bar -->
        <div class="absolute top-0 right-0 h-full w-3 bg-slate-900"></div>

        <div class="text-center mb-8 pr-3">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-400 border-2 border-slate-900 rounded-2xl shadow-[4px_4px_0px_#0f172a] mb-4 text-2xl transform rotate-3 hover:rotate-0 transition-transform">
                🚀
            </div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight">Join the Club</h1>
            <p class="text-sm text-slate-500 font-bold mt-2">Create your student profile</p>
        </div>

        <form action="/auth/signup" method="POST" class="space-y-6 pr-3">
            
            <!-- Name -->
            <div>
                <label class="block text-xs font-extrabold uppercase text-slate-500 mb-2 ml-1 tracking-wider">Full Name</label>
                <div class="relative group">
                    <input type="text" name="name" required placeholder="John Doe" class="thick-input pl-10">
                    <i class="fa-solid fa-user absolute left-3.5 top-4 text-slate-400 text-lg group-hover:text-slate-900 transition-colors"></i>
                </div>
            </div>

            <!-- Email -->
            <div>
                <label class="block text-xs font-extrabold uppercase text-slate-500 mb-2 ml-1 tracking-wider">College Email</label>
                <div class="relative group">
                    <input type="email" name="email" required placeholder="student@campus.edu" class="thick-input pl-10">
                    <i class="fa-solid fa-envelope absolute left-3.5 top-4 text-slate-400 text-lg group-hover:text-slate-900 transition-colors"></i>
                </div>
                <p class="text-[10px] font-bold text-slate-400 mt-1.5 text-right">*Official domain required</p>
            </div>

            <!-- Grid for Phone & Year -->
            <div class="grid grid-cols-2 gap-4">
                <div>
                    <label class="block text-xs font-extrabold uppercase text-slate-500 mb-2 ml-1 tracking-wider">Phone</label>
                    <div class="relative group">
                        <input type="tel" name="phone" required placeholder="987..." class="thick-input pl-10">
                        <i class="fa-solid fa-phone absolute left-3.5 top-4 text-slate-400 text-lg group-hover:text-slate-900 transition-colors"></i>
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-extrabold uppercase text-slate-500 mb-2 ml-1 tracking-wider">Grad Year</label>
                    <div class="relative group">
                        <input type="number" name="grad_year" required min="2024" max="2030" placeholder="202X" class="thick-input pl-10">
                        <i class="fa-solid fa-graduation-cap absolute left-3.5 top-4 text-slate-400 text-lg group-hover:text-slate-900 transition-colors"></i>
                    </div>
                </div>
            </div>

            <!-- Password -->
            <div>
                <label class="block text-xs font-extrabold uppercase text-slate-500 mb-2 ml-1 tracking-wider">Password</label>
                <div class="relative group">
                    <input type="password" name="password" required placeholder="••••••••" class="thick-input pl-10">
                    <i class="fa-solid fa-lock absolute left-3.5 top-4 text-slate-400 text-lg group-hover:text-slate-900 transition-colors"></i>
                </div>
            </div>

            <!-- Submit -->
            <button type="submit" class="thick-btn w-full py-3.5 font-bold tracking-wide mt-2">
                Create Account
            </button>
        </form>

        <div class="mt-8 text-center pr-3">
            <p class="text-slate-500 font-medium text-sm">
                Already a member? 
                <a href="/login" class="text-slate-900 underline decoration-2 decoration-blue-500 underline-offset-4 hover:bg-blue-100 font-bold px-1 rounded transition-colors">Log in</a>
            </p>
        </div>
    </div>
</body>
</html>