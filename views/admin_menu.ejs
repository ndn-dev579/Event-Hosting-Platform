<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen font-sans">

    <nav class="bg-black text-white p-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold tracking-tight">ADMIN CONSOLE</h1>
            <a href="/logout" class="text-sm text-red-400 font-bold hover:text-red-300">Logout</a>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto p-8">
        <h2 class="text-3xl font-black text-gray-900 uppercase mb-8">Management Dashboard</h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            
            <a href="/admin/events/pending" class="block bg-white p-8 border-2 border-black hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all">
                <div class="text-4xl mb-4">⏳</div>
                <h3 class="text-xl font-bold uppercase">Pending Reviews</h3>
                <p class="text-gray-500 text-sm mt-2">Approve or reject events submitted by students.</p>
            </a>

            <a href="/admin/events/history" class="block bg-white p-8 border-2 border-black hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all">
                <div class="text-4xl mb-4">📚</div>
                <h3 class="text-xl font-bold uppercase">Event History</h3>
                <p class="text-gray-500 text-sm mt-2">View published, rejected, and archived events.</p>
            </a>

            <a href="/admin/users" class="block bg-white p-8 border-2 border-black hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] transition-all">
                <div class="text-4xl mb-4">👥</div>
                <h3 class="text-xl font-bold uppercase">User Management</h3>
                <p class="text-gray-500 text-sm mt-2">Manage students, deactivate accounts, and view roles.</p>
            </a>

        </div>
    </div>

</body>
</html>