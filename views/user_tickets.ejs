<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Tickets | Evently</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Courier+Prime:wght@400;700&display=swap" rel="stylesheet">
</head>
<body class="bg-gray-100 min-h-screen font-sans">

    <nav class="bg-white border-b border-gray-200 py-4 px-6">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-black tracking-tighter">EVENTLY.</a>
            <div class="space-x-4 text-sm font-bold">
                <a href="/" class="text-gray-500 hover:text-black">Home</a>
                <a href="/logout" class="text-red-500 hover:text-red-700">Logout</a>
            </div>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto p-6 md:p-12">
        <h1 class="text-4xl font-black uppercase mb-8">My Tickets</h1>

        <% if (myTickets.length === 0) { %>
            <div class="bg-white p-12 text-center border-2 border-dashed border-gray-300 rounded">
                <p class="text-gray-400 font-bold uppercase">No upcoming tickets</p>
                <a href="/" class="text-blue-600 font-bold hover:underline mt-2 inline-block">Browse Events &rarr;</a>
            </div>
        <% } else { %>
            <div class="grid gap-6">
                <% myTickets.forEach(ticket => { %>
                    <div class="bg-white border-l-8 border-black shadow-md flex flex-col md:flex-row overflow-hidden relative">
                        
                        <div class="p-6 flex-1 flex flex-col justify-center">
                            <h2 class="text-2xl font-black uppercase leading-none mb-2"><%= ticket.title %></h2>
                            <div class="text-sm font-bold text-gray-500 space-y-1">
                                <p>📅 <%= ticket.event_date.split('T')[0] %></p>
                                <p>📍 <%= ticket.venue %></p>
                            </div>
                        </div>

                        <div class="relative w-full md:w-0 border-t-2 md:border-t-0 md:border-l-2 border-dashed border-gray-300">
                            <div class="absolute -left-3 -top-3 w-6 h-6 bg-gray-100 rounded-full"></div>
                            <div class="absolute -left-3 -bottom-3 w-6 h-6 bg-gray-100 rounded-full"></div>
                        </div>

                        <div class="bg-gray-50 p-6 md:w-64 flex flex-col items-center justify-center text-center">
                            <div class="w-24 h-24 bg-black mb-3 flex items-center justify-center">
                                <div class="w-20 h-20 border-4 border-white grid grid-cols-4 gap-1 p-1">
                                    <div class="bg-white col-span-2 row-span-2"></div>
                                    <div class="bg-white"></div>
                                    <div class="bg-white col-span-1 row-span-3"></div>
                                </div>
                            </div>
                            <p class="font-mono text-xs font-bold text-gray-500">TICKET ID</p>
                            <p class="font-mono text-lg font-bold tracking-widest text-black"><%= ticket.ticket_code %></p>
                        </div>

                    </div>
                <% }); %>
            </div>
        <% } %>
    </div>

</body>
</html>