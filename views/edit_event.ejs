<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Event | Evently</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen font-sans">

    <nav class="bg-white border-b border-gray-200 py-4 px-6 sticky top-0 z-50">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-black tracking-tighter">EVENTLY.</a>
            <div class="space-x-6 text-sm font-bold text-gray-600">
                <a href="/my-events" class="hover:text-black">&larr; Back to Dashboard</a>
            </div>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto p-6 md:p-12">
        <header class="mb-10">
            <h1 class="text-5xl font-black uppercase tracking-tighter italic">Edit Event</h1>
            <p class="text-gray-500 mt-2 font-medium">Updating this event will set its status back to <span class="text-yellow-600">Pending Review</span>.</p>
        </header>

        <form action="/events/edit/<%= event.id %>" method="POST" class="space-y-8">
            
            <div class="bg-white border-2 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
                <h2 class="text-xl font-black uppercase mb-6 border-b-2 border-black pb-2">1. Basic Information</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="flex flex-col">
                        <label class="text-xs font-bold uppercase mb-1">Event Title</label>
                        <input type="text" name="title" value="<%= event.title %>" required 
                               class="border-2 border-black p-3 focus:bg-yellow-50 outline-none font-bold">
                    </div>

                    <div class="flex flex-col">
                        <label class="text-xs font-bold uppercase mb-1">Sub-Title / Catchphrase</label>
                        <input type="text" name="sub_title" value="<%= event.sub_title %>"
                               class="border-2 border-black p-3 focus:bg-yellow-50 outline-none">
                    </div>

                    <div class="flex flex-col">
                        <label class="text-xs font-bold uppercase mb-1">Venue</label>
                        <input type="text" name="venue" value="<%= event.venue %>" required
                               class="border-2 border-black p-3 focus:bg-yellow-50 outline-none">
                    </div>

                    <div class="flex flex-col">
                        <label class="text-xs font-bold uppercase mb-1">Event Date & Time</label>
                        <input type="datetime-local" name="event_date" 
                               value="<%= event.event_date.substring(0, 16) %>" required
                               class="border-2 border-black p-3 focus:bg-yellow-50 outline-none">
                    </div>
                </div>

                <div class="flex flex-col mt-6">
                    <label class="text-xs font-bold uppercase mb-1">Description</label>
                    <textarea name="description" rows="4" required
                              class="border-2 border-black p-3 focus:bg-yellow-50 outline-none"><%= event.description %></textarea>
                </div>
            </div>

            <div class="bg-white border-2 border-black p-8 shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
                <h2 class="text-xl font-black uppercase mb-6 border-b-2 border-black pb-2">2. Logistics & Pricing</h2>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="flex flex-col">
                        <label class="text-xs font-bold uppercase mb-1">Duration (Mins)</label>
                        <input type="number" name="duration" value="<%= event.duration %>" required
                               class="border-2 border-black p-3 focus:bg-yellow-50 outline-none">
                    </div>

                    <div class="flex flex-col">
                        <label class="text-xs font-bold uppercase mb-1">Total Seats</label>
                        <input type="number" name="total_seats" value="<%= event.total_seats %>" required
                               class="border-2 border-black p-3 focus:bg-yellow-50 outline-none">
                    </div>

                    <div class="flex flex-col">
                        <label class="text-xs font-bold uppercase mb-1">Price (₹)</label>
                        <input type="number" step="0.01" name="price" value="<%= event.price %>"
                               class="border-2 border-black p-3 focus:bg-yellow-50 outline-none font-mono">
                    </div>
                </div>

                <div class="mt-6 flex items-center space-x-3">
                    <input type="checkbox" name="is_paid" id="is_paid" 
                           class="w-5 h-5 accent-black" <%= event.is_paid ? 'checked' : '' %>>
                    <label for="is_paid" class="text-sm font-black uppercase cursor-pointer">This is a Paid Event</label>
                </div>
            </div>

            <div class="flex flex-col items-center">
                <button type="submit" 
                        class="w-full md:w-auto bg-black text-white text-xl font-black uppercase px-12 py-4 hover:bg-yellow-400 hover:text-black transition-colors shadow-[8px_8px_0px_0px_rgba(0,0,0,0.3)] hover:shadow-none active:translate-x-1 active:translate-y-1">
                    Update & Resubmit Event
                </button>
                <p class="text-[10px] text-gray-400 mt-4 uppercase tracking-widest text-center">
                    Original Submission: <%= event.created_at %>
                </p>
            </div>

        </form>
    </main>

    <script>
        // Simple logic to disable/enable price field based on checkbox
        const isPaidCheckbox = document.getElementById('is_paid');
        const priceInput = document.querySelector('input[name="price"]');

        isPaidCheckbox.addEventListener('change', () => {
            if(!isPaidCheckbox.checked) {
                priceInput.value = 0;
                priceInput.classList.add('bg-gray-100');
            } else {
                priceInput.classList.remove('bg-gray-100');
            }
        });
    </script>
</body>
</html>