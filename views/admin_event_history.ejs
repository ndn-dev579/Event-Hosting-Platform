<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event History | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen font-sans">

    <nav class="bg-black text-white p-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold">ADMIN HISTORY</h1>
            <a href="/admin/dashboard" class="text-sm hover:text-gray-300">Back to Dashboard</a>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto p-8">
        <h2 class="text-3xl font-black text-gray-900 uppercase mb-6">Event Log</h2>

        <div class="bg-white shadow-lg border border-gray-200 overflow-hidden">
            <table class="min-w-full leading-normal">
                <thead>
                    <tr class="bg-gray-50 border-b-2 border-gray-200 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                        <th class="px-5 py-3">Event Name</th>
                        <th class="px-5 py-3">Creator</th>
                        <th class="px-5 py-3">Date</th>
                        <th class="px-5 py-3">Status</th>
                        <th class="px-5 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (!eventHistory || eventHistory.length === 0) { %>
                        <tr>
                            <td colspan="5" class="px-5 py-5 text-center text-gray-500">No history found.</td>
                        </tr>
                    <% } else { %>
                        <% eventHistory.forEach(event => { %>
                        <tr class="border-b border-gray-200 hover:bg-gray-50">
                            <td class="px-5 py-5 text-sm font-bold text-gray-900">
                                <%= event.title %>
                            </td>
                            <td class="px-5 py-5 text-sm text-gray-600">
                                <%= event.creator_name %>
                            </td>
                            <td class="px-5 py-5 text-sm text-gray-600">
                                <%= event.event_date %>
                            </td>
                            <td class="px-5 py-5 text-sm">
                                <% if (event.event_status === 'published') { %>
                                    <span class="bg-green-100 text-green-800 px-2 py-1 rounded-full text-xs font-bold uppercase">Published</span>
                                <% } else if (event.event_status === 'rejected') { %>
                                    <span class="bg-red-100 text-red-800 px-2 py-1 rounded-full text-xs font-bold uppercase">Rejected</span>
                                <% } else { %>
                                    <span class="bg-gray-100 text-gray-800 px-2 py-1 rounded-full text-xs font-bold uppercase"><%= event.event_status %></span>
                                <% } %>
                            </td>
                            <td class="px-5 py-5 text-sm">
                                <% if (event.event_status === 'published') { %>
                                    <form action="/admin/event-action" method="POST" class="inline">
                                        <input type="hidden" name="event_id" value="<%= event.id %>">
                                        <input type="hidden" name="action" value="archived">
                                        <button type="submit" class="text-red-600 hover:text-red-900 font-bold text-xs uppercase border border-red-200 px-2 py-1 hover:bg-red-50">
                                            Archive
                                        </button>
                                    </form>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>