<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Event History | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen font-sans">

    <nav class="bg-black text-white p-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold tracking-tighter uppercase">Admin History</h1>
            <a href="/admin/dashboard" class="text-sm hover:text-gray-300 font-bold uppercase">Back to Dashboard</a>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto p-8">
        <h2 class="text-3xl font-black text-gray-900 uppercase mb-6 italic">Event Log</h2>

        <div class="bg-white shadow-lg border-2 border-black overflow-hidden">
            <table class="min-w-full leading-normal">
                <thead>
                    <tr class="bg-gray-50 border-b-2 border-black text-left text-xs font-black text-gray-600 uppercase tracking-wider">
                        <th class="px-5 py-3 text-black">Event Name</th>
                        <th class="px-5 py-3">Creator</th>
                        <th class="px-5 py-3">Date</th>
                        <th class="px-5 py-3">Status</th>
                        <th class="px-5 py-3 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    <% if (!eventHistory || eventHistory.length === 0) { %>
                        <tr>
                            <td colspan="5" class="px-5 py-10 text-center text-gray-400 font-bold uppercase italic">No history found.</td>
                        </tr>
                    <% } else { %>
                        <% eventHistory.forEach(event => { %>
                        <tr class="border-b border-gray-200 hover:bg-yellow-50 transition-colors">
                            <td class="px-5 py-5 text-sm font-bold text-gray-900">
                                <%= event.title %>
                            </td>
                            <td class="px-5 py-5 text-sm text-gray-600">
                                <%= event.creator_name %>
                            </td>
                            <td class="px-5 py-5 text-sm text-gray-600">
                                <%= event.event_date.split('T')[0] %>
                            </td>
                            <td class="px-5 py-5 text-sm">
                                <% if (event.event_status === 'published') { %>
                                    <span class="bg-green-500 text-white px-2 py-0.5 text-[10px] font-black uppercase">Published</span>
                                <% } else if (event.event_status === 'rejected') { %>
                                    <span class="bg-red-500 text-white px-2 py-0.5 text-[10px] font-black uppercase">Rejected</span>
                                <% } else { %>
                                    <span class="bg-gray-800 text-white px-2 py-0.5 text-[10px] font-black uppercase"><%= event.event_status %></span>
                                <% } %>
                            </td>

                            <td class="px-5 py-5 text-sm text-right flex justify-end items-center space-x-2">
                                <a href="/events/view/<%= event.id %>" class="text-blue-600 hover:text-blue-800 font-bold text-[10px] uppercase border-b-2 border-blue-600">View</a>
                                
                                <a href="/events/edit/<%= event.id %>" class="bg-black text-white px-3 py-1 font-black text-[10px] uppercase hover:bg-yellow-400 hover:text-black transition shadow-[2px_2px_0px_0px_rgba(0,0,0,0.3)]">
                                    Override & Edit
                                </a>

                                <% if (event.event_status === 'published') { %>
                                    <form action="/admin/event-action" method="POST" class="inline" onsubmit="return confirm('Archive this event? It will no longer be visible on the home feed.')">
                                        <input type="hidden" name="event_id" value="<%= event.id %>">
                                        <input type="hidden" name="action" value="archived">
                                        <button type="submit" class="text-gray-400 hover:text-red-600 transition">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                                            </svg>
                                        </button>
                                    </form>
                                <% } %>
                            </td>
                        </tr>
                        <% }); %>
                    <% } %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>