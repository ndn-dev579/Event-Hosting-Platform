<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>User Management | Admin</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen font-sans">

    <nav class="bg-black text-white p-4">
        <div class="max-w-6xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-bold">USER MANAGER</h1>
            <a href="/admin/dashboard" class="text-sm hover:text-gray-300">Back to Dashboard</a>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto p-8">
        <h2 class="text-3xl font-black text-gray-900 uppercase mb-6">Registered Users</h2>

        <div class="bg-white shadow-lg border border-gray-200 overflow-hidden">
            <table class="min-w-full leading-normal">
                <thead>
                    <tr class="bg-gray-50 border-b-2 border-gray-200 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">
                        <th class="px-5 py-3">Name</th>
                        <th class="px-5 py-3">Email</th>
                        <th class="px-5 py-3">Role</th>
                        <th class="px-5 py-3">Grad Year</th>
                        <th class="px-5 py-3">Status</th>
                        <th class="px-5 py-3">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% allUsers.forEach(u => { %>
                    <tr class="border-b border-gray-200 hover:bg-gray-50">
                        <td class="px-5 py-5 text-sm font-bold text-gray-900">
                            <%= u.name %>
                            <% if (u.id === user.id) { %> <span class="text-gray-400 text-xs">(You)</span> <% } %>
                        </td>
                        <td class="px-5 py-5 text-sm text-gray-600">
                            <%= u.email %>
                        </td>
                        <td class="px-5 py-5 text-sm">
                            <span class="<%= u.role === 'admin' ? 'text-purple-600' : 'text-blue-600' %> font-bold uppercase text-xs">
                                <%= u.role %>
                            </span>
                        </td>
                        <td class="px-5 py-5 text-sm font-mono <%= u.grad_year < currentYear ? 'text-red-500' : 'text-gray-600' %>">
                            <%= u.grad_year %>
                        </td>
                        <td class="px-5 py-5 text-sm">
                            <% if (u.status === 'active') { %>
                                <span class="bg-green-100 text-green-800 px-2 py-1 rounded-full text-xs font-bold">Active</span>
                            <% } else { %>
                                <span class="bg-red-100 text-red-800 px-2 py-1 rounded-full text-xs font-bold">Inactive</span>
                            <% } %>
                        </td>
                        <td class="px-5 py-5 text-sm">
                            <% if (u.role !== 'admin') { %>
                                <form action="/admin/user-status" method="POST">
                                    <input type="hidden" name="target_user_id" value="<%= u.id %>">
                                    <% if (u.status === 'active') { %>
                                        <input type="hidden" name="new_status" value="inactive">
                                        <button class="text-red-600 hover:underline font-bold text-xs uppercase">Deactivate</button>
                                    <% } else { %>
                                        <input type="hidden" name="new_status" value="active">
                                        <button class="text-green-600 hover:underline font-bold text-xs uppercase">Activate</button>
                                    <% } %>
                                </form>
                            <% } %>
                        </td>
                    </tr>
                    <% }); %>
                </tbody>
            </table>
        </div>
    </div>
</body>
</html>