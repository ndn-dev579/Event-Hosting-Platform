<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Events | Evently</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen font-sans">

    <nav class="bg-white border-b border-gray-200 py-4 px-6 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-black tracking-tighter">EVENTLY.</a>
            <div class="space-x-6 text-sm font-bold text-gray-600">
                
                <a href="/" class="hover:text-black">Home</a>
                <a href="/events" class="text-black">All Events</a>
                <% if (user) { %>
                    <a href="/my-events" class="hover:text-black">Hosted Events</a> 
                    <a href="/my-tickets" class="hover:text-black">My Tickets</a>
                    <a href="/logout" class="text-red-500 hover:text-red-700">Logout</a>
                <% } else { %>
                    <a href="/login" class="text-blue-600 hover:text-blue-800">Login</a>
                <% } %>
            </div>
        </div>
    </nav>

    <header class="bg-black text-white py-12 text-center">
        <h1 class="text-4xl font-black uppercase tracking-tight">Discover Events</h1>
        <p class="text-gray-400 mt-2">Browse all upcoming activities on campus</p>
    </header>

    <main class="max-w-7xl mx-auto p-6 md:p-12">
        <% if (events.length === 0) { %>
            <div class="text-center py-20">
                <p class="text-gray-400 text-xl font-bold">No upcoming events found.</p>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
                <% events.forEach(event => { %>
                    <a href="/events/view/<%= event.id %>" class="group block bg-white border border-gray-200 hover:border-black transition-all hover:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]">
                        <div class="<%= event.css_class %> h-48 w-full relative overflow-hidden flex items-center justify-center p-4 border-b border-gray-200">
                            <h3 class="text-2xl font-black uppercase text-center leading-none" style="color: <%= event.poster_color || '#000' %>">
                                <%= event.title %>
                            </h3>
                        </div>
                        
                        <div class="p-6">
                            <div class="flex justify-between items-start mb-2">
                                <span class="text-xs font-bold bg-gray-100 px-2 py-1 uppercase tracking-wide">
                                    <%= event.hosted_by %>
                                </span>
                                <% if (event.seats_taken >= event.total_seats) { %>
                                    <span class="text-xs font-bold text-red-600 uppercase">Sold Out</span>
                                <% } else { %>
                                    <span class="text-xs font-bold text-green-600 uppercase">Open</span>
                                <% } %>
                            </div>
                            
                            <h3 class="text-xl font-bold text-gray-900 mb-1 group-hover:underline decoration-2 underline-offset-4">
                                <%= event.title %>
                            </h3>
                            <p class="text-sm text-gray-500 mb-4"><%= event.event_date.split('T')[0] %> • <%= event.venue %></p>
                            
                            <span class="text-sm font-bold text-black border-b-2 border-black pb-0.5">View Details &rarr;</span>
                        </div>
                    </a>
                <% }); %>
            </div>
        <% } %>
    </main>

</body>
</html>