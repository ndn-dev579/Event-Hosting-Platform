<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Events | Evently</title>
    <script src="https://cdn.tailwindcss.com"></script>

    <style>
        .event-card-header {
            background-image: url("https://www.transparenttextures.com/patterns/p6-static.png");
            /* Subtle noise for texture */
        }
    </style>
</head>

<body class="bg-gray-50 min-h-screen font-sans">

    <nav class="bg-white border-b border-gray-200 py-4 px-6 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-black tracking-tighter">EVENTLY.</a>
            <div class="space-x-6 text-sm font-bold text-gray-600">
                <a href="/" class="hover:text-black">Home</a>
                <a href="/events" class="text-black">All Events</a>
                <% if (user) { %>
                    <a href="/my-events" class="hover:text-black">Hosted Events</a>
                    <a href="/my-tickets" class="hover:text-black">My Tickets</a>
                    <a href="/logout" class="text-red-500 hover:text-red-700">Logout</a>
                    <% } else { %>
                        <a href="/login" class="text-blue-600 hover:text-blue-800">Login</a>
                        <% } %>
            </div>
        </div>
    </nav>

    <header class="bg-black text-white py-12 text-center">
        <h1 class="text-4xl font-black uppercase tracking-tight">Discover Events</h1>
        <p class="text-gray-400 mt-2 mb-8">Browse all upcoming activities on campus</p>

        <div class="max-w-xl mx-auto px-6">
            <input type="text" id="eventSearch" placeholder="Search by name, venue, or host..."
                class="w-full p-4 rounded-none border-0 text-black font-bold focus:ring-4 focus:ring-yellow-400 outline-none"
                value="<%= typeof searchTerm !== 'undefined' ? searchTerm : '' %>">
        </div>
    </header>

    <main class="max-w-7xl mx-auto p-6 md:p-12">
        <div id="eventsContainer">
            <% if (events.length===0) { %>
                <div class="text-center py-20">
                    <p class="text-gray-400 text-xl font-bold">No upcoming events found.</p>
                </div>
                <% } else { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
                        <% events.forEach(event=> { %>
                            <a href="/events/view/<%= event.id %>"
                                class="group block bg-white border-2 border-black hover:-translate-x-1 hover:-translate-y-1 transition-all hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)]">


                                <div
                                    class="h-48 w-full relative overflow-hidden flex items-center justify-center p-6 border-b-2 border-black bg-white">

                                    <div class="absolute inset-0 opacity-[0.5]"
                                        style="background-color: <%= event.poster_color || '#000' %> !important;">
                                    </div>

                                    <div class="event-card-header absolute inset-0 opacity-30 pointer-events-none">
                                    </div>

                                    <h3
                                        class="relative z-10 text-3xl font-black uppercase text-center leading-[0.85] tracking-tighter text-black italic drop-shadow-[2px_2px_0px_rgba(255,255,255,1)]">
                                        <%= event.title %>
                                    </h3>

                                    <div
                                        class="absolute bottom-3 right-3 bg-black text-white text-[10px] font-bold px-2 py-1 uppercase tracking-widest z-20">
                                        <%= event.event_date.split('T')[0] %>
                                    </div>
                                </div>


                                <div class="p-6">
                                    <div class="flex justify-between items-start mb-4">
                                        <span
                                            class="text-[10px] font-black bg-black text-white px-2 py-0.5 uppercase tracking-tighter">
                                            <%= event.hosted_by %>
                                        </span>
                                        <% if (event.seats_taken>= event.total_seats) { %>
                                            <span
                                                class="text-[10px] font-black text-red-600 uppercase border-2 border-red-600 px-2 py-0.5">Sold
                                                Out</span>
                                            <% } else { %>
                                                <span
                                                    class="text-[10px] font-black text-green-600 uppercase border-2 border-green-600 px-2 py-0.5">Tickets
                                                    Open</span>
                                                <% } %>
                                    </div>

                                    <h3
                                        class="text-xl font-black text-black uppercase mb-1 leading-tight group-hover:underline underline-offset-4">
                                        <%= event.title %>
                                    </h3>
                                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">
                                        <%= event.venue %>
                                    </p>

                                    <div class="mt-6 flex items-center justify-between">
                                        <span
                                            class="text-xs font-black uppercase tracking-widest group-hover:text-red-600 transition-colors">View
                                            Details &rarr;</span>
                                        <span class="text-xs font-mono text-gray-400">#<%=
                                                event.id.toString().padStart(4, '0' ) %></span>
                                    </div>
                                </div>
                            </a>
                            <% }); %>
                    </div>
                    <% } %>
        </div>
    </main>

    <script>
        const searchInput = document.getElementById('eventSearch');
        const container = document.getElementById('eventsContainer');

        searchInput.addEventListener('input', (e) => {
            const query = e.target.value;

            fetch(`/events?q=${encodeURIComponent(query)}`, {
                headers: { 'Accept': 'application/json' }
            })
                .then(res => res.json())
                .then(data => {
                    updateUI(data.events);
                });
        });

        function updateUI(events) {
            if (events.length === 0) {
                container.innerHTML = `<div class="text-center py-20"><p class="text-gray-400 text-xl font-bold">No events found.</p></div>`;
                return;
            }

            let html = '<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">';
            events.forEach(event => {
                const statusLabel = event.seats_taken >= event.total_seats
                    ? '<span class="text-[10px] font-black text-red-600 uppercase border-2 border-red-600 px-2 py-0.5">Sold Out</span>'
                    : '<span class="text-[10px] font-black text-green-600 uppercase border-2 border-green-600 px-2 py-0.5">Tickets Open</span>';

                html += `
                <a href="/events/view/${event.id}" class="group block bg-white border-2 border-black hover:-translate-x-1 hover:-translate-y-1 transition-all hover:shadow-[12px_12px_0px_0px_rgba(0,0,0,1)]">
                    <div class="event-card-header h-48 w-full relative overflow-hidden flex items-center justify-center p-6 border-b-2 border-black" style="background-color: ${event.poster_color || '#000'}">
                        <h3 class="text-3xl font-black uppercase text-center leading-[0.85] tracking-tighter text-white drop-shadow-[3px_3px_0px_rgba(0,0,0,1)] italic">
                            ${event.title}
                        </h3>
                        <div class="absolute bottom-3 right-3 bg-black text-white text-[10px] font-bold px-2 py-1 uppercase tracking-widest">
                            ${event.event_date.split('T')[0]}
                        </div>
                    </div>
                    <div class="p-6">
                        <div class="flex justify-between items-start mb-4">
                            <span class="text-[10px] font-black bg-black text-white px-2 py-0.5 uppercase tracking-tighter">${event.hosted_by}</span>
                            ${statusLabel}
                        </div>
                        <h3 class="text-xl font-black text-black uppercase mb-1 leading-tight group-hover:underline underline-offset-4">${event.title}</h3>
                        <p class="text-xs font-bold text-gray-500 uppercase tracking-wide">${event.venue}</p>
                        <div class="mt-6 flex items-center justify-between">
                            <span class="text-xs font-black uppercase tracking-widest">View Details &rarr;</span>
                            <span class="text-xs font-mono text-gray-400">#${event.id.toString().padStart(4, '0')}</span>
                        </div>
                    </div>
                </a>`;
            });
            html += '</div>';
            container.innerHTML = html;
        }
    </script>
</body>

</html>