<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Hosted Events | Evently</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen font-sans">

    <nav class="bg-white border-b border-gray-200 py-4 px-6">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <a href="/" class="text-2xl font-black tracking-tighter">EVENTLY.</a>
            <div class="space-x-4 text-sm font-bold">
                <a href="/" class="text-gray-500 hover:text-black">Home</a>
                <a href="/logout" class="text-red-500 hover:text-red-700">Logout</a>
            </div>
        </div>
    </nav>

    <div class="max-w-4xl mx-auto p-6 md:p-12">
        <div class="flex justify-between items-end mb-8">
            <h1 class="text-4xl font-black uppercase">My Events</h1>
            <a href="/events/create" class="bg-black text-white px-4 py-2 font-bold text-sm hover:bg-gray-800 transition">
                + Create New Event
            </a>
        </div>

        <% if (myEvents.length === 0) { %>
            <div class="text-center py-12 text-gray-400">
                <p class="font-bold">You haven't hosted any events yet.</p>
            </div>
        <% } else { %>
            <div class="bg-white shadow border border-gray-200 rounded-lg overflow-hidden">
                <table class="min-w-full leading-normal">
                    <thead class="bg-gray-50 border-b border-gray-200">
                        <tr>
                            <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Event</th>
                            <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Date</th>
                            <th class="px-5 py-3 text-left text-xs font-bold text-gray-500 uppercase tracking-wider">Status</th>
                            <th class="px-5 py-3 text-right text-xs font-bold text-gray-500 uppercase tracking-wider">Link</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% myEvents.forEach(event => { %>
                            <tr class="border-b border-gray-200 hover:bg-gray-50">
                                <td class="px-5 py-4 text-sm font-bold text-gray-900"><%= event.title %></td>
                                <td class="px-5 py-4 text-sm text-gray-600"><%= event.event_date.split('T')[0] %></td>
                                <td class="px-5 py-4 text-sm">
                                    <% if (event.event_status === 'pending_review') { %>
                                        <span class="bg-yellow-100 text-yellow-800 px-2 py-1 rounded text-xs font-bold uppercase">Pending</span>
                                    <% } else if (event.event_status === 'published') { %>
                                        <span class="bg-green-100 text-green-800 px-2 py-1 rounded text-xs font-bold uppercase">Published</span>
                                    <% } else if (event.event_status === 'rejected') { %>
                                        <span class="bg-red-100 text-red-800 px-2 py-1 rounded text-xs font-bold uppercase">Rejected</span>
                                    <% } %>
                                </td>
                                <td class="px-5 py-4 text-sm text-right">
                                    <a href="/events/view/<%= event.id %>" class="text-blue-600 hover:underline font-bold text-xs uppercase">View &rarr;</a>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>

</body>
</html>